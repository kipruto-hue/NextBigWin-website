# ── App ──────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5000

# ── MongoDB ───────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/nextbigwin

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ── Safaricom Daraja (M-PESA) ─────────────────────────────────
# Get from https://developer.safaricom.co.ke
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
# Where Safaricom POSTs payment results (must be public HTTPS)
MPESA_CALLBACK_URL=https://yourdomain.co.ke/api/mpesa/callback

# ── Africa's Talking (SMS + USSD) ────────────────────────────
# Get from https://africastalking.com
AT_API_KEY=your_africastalking_api_key
AT_USERNAME=sandbox
AT_SENDER_ID=NEXTBIGWIN

# ── Admin seed ────────────────────────────────────────────────
ADMIN_EMAIL=admin@nextbigwin.co.ke
ADMIN_PASSWORD=Change_This_Strong_Password_123!

# ── Ticket pricing ────────────────────────────────────────────
TICKET_PRICE=100
